# =============================================================================
# Application Configuration
# =============================================================================

# Application name
APP_NAME=emotion-detection-pipeline

# Application version (semantic versioning)
VERSION=0.1.0

# List of authors (comma-separated)
AUTHORS=[]

# Application status: development or production
STATUS=development

# =============================================================================
# Debug Settings
# =============================================================================

# Enable debug mode (true/false)
# Note: Cannot be true in production environment
DEBUG=false

# =============================================================================
# Logging Configuration
# =============================================================================

# Logging level: CRITICAL, FATAL, ERROR, WARNING, WARN, INFO, DEBUG, NOTSET
LOG_LEVEL=DEBUG

# Log file path (optional - will use default if not specified)
# Default: logs/emotion-detection-pipeline.log
# LOG_FILE=

# =============================================================================
# API Configuration
# =============================================================================

# API server port
API_PORT=8000

# =============================================================================
# External Services
# =============================================================================

# AssemblyAI API key (required)
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here
